// Prisma Schema — Timekeeping System
// Generator: prisma-client-js | Datasource: PostgreSQL
// Version constraint: Prisma ^6.0.0 — DO NOT upgrade to v7 (breaking changes)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  MANAGER
  EMPLOYEE
}

enum CalcStatus {
  SHORTHOURS
  DAYOFF
  COMPLETED
  WEEKEND
}

enum RequestType {
  OT
  EXPLANATION
  LEAVE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuthMethod {
  RFID
  FINGERPRINT
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

// ─────────────────────────────────────────────
// 4.1 Employees — Core Identity
// ─────────────────────────────────────────────
model Employee {
  employee_id           Int               @id @default(autoincrement())
  email                 String            @unique
  password_hash         String
  full_name             String
  role                  Role              @default(EMPLOYEE)
  date_of_birth         DateTime?         @db.Date
  hourly_rate           Decimal           @db.Decimal(10, 2)
  rfid_tag              String?           @unique
  template_fingerprint  String?           @db.Text
  must_change_password  Boolean           @default(true)
  is_active             Boolean           @default(true)
  mappings              Mapping[]
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt

  daily_attendances DailyAttendance[]
  monthly_limits    MonthlyLimit[]
  requests          Request[]
  checkin_logs      CheckInLog[]
  notifications     Notification[]

  @@map("employees")
}

model Device {
  device_id    Int              @id @default(autoincrement())
  mac_addr     String           @unique
  name         String?
  status       DeviceStatus?    @default(ACTIVE)

  checkin_logs CheckInLog[]
  mappings     Mapping[]

  @@map("devices")
}

model CheckInLog {
  log_id       BigInt     @id @default(autoincrement())
  employee_id  Int
  device_id    Int
  timestamp    DateTime
  auth_method  AuthMethod
  sync_hash    String     @unique @db.VarChar(255)

  employee     Employee   @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)
  device       Device     @relation(fields: [device_id], references: [device_id], onDelete: Restrict)

  @@index([employee_id, timestamp])
  @@index([device_id, timestamp])
  @@map("checkinlogs")
}

model DailyAttendance {
  attendance_id   BigInt            @id @default(autoincrement())
  employee_id     Int
  date            DateTime          @db.Date
  checkin_time    DateTime?         @db.Time(0)
  checkout_time   DateTime?         @db.Time(0)
  missing_minutes Int               @default(0)
  total_workday   Decimal           @default(0) @db.Decimal(5, 4)
  status          CalcStatus        @default(COMPLETED)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt  

  employee        Employee     @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)
  requests        Request[]

  @@unique([employee_id, date])
  @@index([employee_id])
  @@map("dailyattendance")
}

model MonthlyLimit {
  limit_id           Int       @id @default(autoincrement())
  employee_id        Int
  month_year         String    @db.VarChar(7)
  explanation_count  Int       @default(0)

  employee           Employee  @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)

  @@unique([employee_id, month_year])
  @@index([employee_id])
  @@map("monthlylimits")
}

model Request {
  request_id     Int              @id @default(autoincrement())
  employee_id    Int
  attendance_id  BigInt?
  type           RequestType
  status         RequestStatus    @default(PENDING)
  date           DateTime         @db.Date
  start_time     DateTime?        @db.Time(0)
  end_time       DateTime?        @db.Time(0)
  reason         String?          @db.Text
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  employee       Employee       @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)
  attendance     DailyAttendance? @relation(fields: [attendance_id], references: [attendance_id], onDelete: SetNull)

  @@index([employee_id])
  @@index([attendance_id])
  @@index([date])
  @@map("requests")
}

model Mapping {
  mapping_id     Int      @id @default(autoincrement())
  device_id      Int
  employee_id    Int
  fingerprint_id Int?     

  employee       Employee @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)
  device         Device   @relation(fields: [device_id], references: [device_id], onDelete: Cascade)

  @@unique([device_id, fingerprint_id])
  @@unique([device_id, employee_id])
  @@index([employee_id])
  @@map("mappings")
}

model Notification {
  notification_id  Int      @id @default(autoincrement())
  employee_id      Int
  type             String   // 'REQUEST_APPROVED' | 'REQUEST_REJECTED' | 'PAYROLL'
  title            String
  content          String?
  reference_id     Int?     // request_id or payroll record id
  metadata         String?  @db.Text  // JSON for additional data (file path, etc.)
  is_read          Boolean  @default(false)
  created_at       DateTime @default(now())

  employee        Employee @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)

  @@index([employee_id, is_read])
  @@map("notifications")
}
